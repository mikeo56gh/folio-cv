# ─── NEON DATABASE ────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@ep-xxx.eu-west-2.aws.neon.tech/neondb?sslmode=require

# ─── NEON AUTH ────────────────────────────────────────────────
# Get from: neon.tech → your project → Auth → Configuration → Auth URL
NEON_AUTH_BASE_URL=https://ep-xxx.neonauth.eu-west-2.aws.neon.tech/neondb/auth

# Cookie secret — generate with: openssl rand -base64 32
# Or use: https://generate-secret.vercel.app/32
NEON_AUTH_COOKIE_SECRET=your-random-32-char-secret-here

# ─── ANTHROPIC ────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# ─── STRIPE ───────────────────────────────────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_your-key
STRIPE_SECRET_KEY=sk_live_your-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
STRIPE_PRICE_SPRINT=price_your-sprint-price-id
STRIPE_PRICE_PRO=price_your-pro-price-id
STRIPE_PRICE_BOOST=price_your-boost-price-id
STRIPE_PRICE_RECRUITER=price_your-recruiter-price-id

# ─── JOBS API ─────────────────────────────────────────────────
ADZUNA_APP_ID=your-adzuna-app-id
ADZUNA_API_KEY=your-adzuna-api-key

# ─── EMAIL ────────────────────────────────────────────────────
RESEND_API_KEY=re_your-resend-key

# ─── CRON ─────────────────────────────────────────────────────
CRON_SECRET=your-random-secret

# ─── APP ──────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://folio-cv-production.up.railway.app
