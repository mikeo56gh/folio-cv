{
  "manifest_version": 3,
  "name": "Folio CV Builder",
  "description": "Apply to any job with a tailored CV in one click. Powered by Folio.",
  "version": "1.0.0",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    },
    "default_title": "Apply with Folio"
  },
  "permissions": [
    "activeTab",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "https://linkedin.com/*",
    "https://www.linkedin.com/*",
    "https://indeed.com/*",
    "https://www.indeed.com/*",
    "https://reed.co.uk/*",
    "https://www.reed.co.uk/*",
    "https://glassdoor.co.uk/*",
    "https://www.glassdoor.co.uk/*",
    "https://totaljobs.com/*",
    "https://www.totaljobs.com/*",
    "https://cvlibrary.co.uk/*",
    "https://www.cvlibrary.co.uk/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.linkedin.com/jobs/*",
        "https://www.indeed.com/*",
        "https://www.reed.co.uk/jobs/*",
        "https://www.glassdoor.co.uk/job-listing/*",
        "https://www.totaljobs.com/job/*",
        "https://www.cvlibrary.co.uk/job/*"
      ],
      "js": ["content.js"]
    }
  ]
}
